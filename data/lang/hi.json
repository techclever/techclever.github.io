  "about.title": "TechClever \u0915\u0947 \u092c\u093e\u0930\u0947 \u092e\u0947\u0902",
  "about.text1": "TechClever \u090f\u0915 \u092e\u0941\u092b\u093c\u094d\u0924 \u0914\u0930 \u0935\u093f\u091c\u094d\u091e\u093e\u092a\u0928-\u0930\u0939\u093f\u0924 \u092a\u094d\u0932\u0948\u091f\u092b\u093c\u0949\u0930\u094d\u092e \u0939\u0948 \u091c\u094b \u091f\u0947\u0915\u094d\u0928\u0949\u0932\u0949\u091c\u0940 \u0915\u0940 \u0926\u0941\u0928\u093f\u092f\u093e \u0915\u093e \u0938\u0930\u094d\u0935\u0936\u094d\u0930\u0947\u0937\u094d\u0920 \u092a\u094d\u0930\u0938\u094d\u0924\u0941\u0924 \u0915\u0930\u0924\u093e \u0939\u0948 \u2014 \u0917\u0947\u092e\u094d\u0938, AI \u091f\u0942\u0932\u094d\u0938, \u0921\u0947\u0935\u0932\u092a\u0930 \u0930\u093f\u0938\u094b\u0930\u094d\u0938, \u0909\u0924\u094d\u092a\u093e\u0926\u0915\u0924\u093e \u0910\u092a\u094d\u0938 \u0914\u0930 \u0939\u093e\u0930\u094d\u0921\u0935\u0947\u092f\u0930 \u0917\u093e\u0907\u0921\u094d\u0938\u0964",
  "about.text2": "\u0939\u092e \u092e\u093e\u0928\u0924\u0947 \u0939\u0948\u0902 \u0915\u093f \u0905\u091a\u094d\u091b\u0940 \u091f\u0947\u0915 \u091c\u093e\u0928\u0915\u093e\u0930\u0940 \u0938\u092c\u0915\u0947 \u0932\u093f\u090f \u0938\u0941\u0932\u092d \u0939\u094b\u0928\u0940 \u091a\u093e\u0939\u093f\u090f \u2014 \u092c\u093f\u0928\u093e \u092a\u0947\u0935\u0949\u0932, \u0915\u094d\u0932\u093f\u0915\u092c\u0947\u091f \u092f\u093e \u091b\u093f\u092a\u0947 \u0939\u0941\u090f \u0907\u0930\u093e\u0926\u094b\u0902 \u0915\u0947\u0964 \u0938\u093f\u0930\u094d\u092b\u093c \u0908\u092e\u093e\u0928\u0926\u093e\u0930 \u0914\u0930 \u091a\u0941\u0928\u093f\u0902\u0926\u093e \u0938\u093f\u092b\u093c\u093e\u0930\u093f\u0936\u0947\u0902\u0964",
  "about.text3": "\u0915\u094b\u0908 \u092a\u094d\u0930\u093e\u092f\u094b\u091c\u093f\u0924 \u0938\u093e\u092e\u0917\u094d\u0930\u0940 \u0928\u0939\u0940\u0902\u0964 \u0915\u094b\u0908 \u090f\u092b\u093f\u0932\u093f\u090f\u091f \u091a\u093e\u0932\u0947\u0902 \u0928\u0939\u0940\u0902\u0964 \u0938\u093f\u0930\u094d\u092b\u093c \u0917\u0941\u0923\u0935\u0924\u094d\u0924\u093e\u092a\u0942\u0930\u094d\u0923 \u091a\u0941\u0928\u093e\u0935, \u0938\u094d\u092a\u0937\u094d\u091f \u0930\u0942\u092a \u0938\u0947 \u092c\u0924\u093e\u090f \u0917\u090f\u0964",
  "about.values_title": "\u0939\u092e\u093e\u0930\u0947 \u092e\u0942\u0932\u094d\u092f",
  "about.value1": "\u092e\u093e\u0924\u094d\u0930\u093e \u0938\u0947 \u0905\u0927\u093f\u0915 \u0917\u0941\u0923\u0935\u0924\u094d\u0924\u093e \u2014 \u0939\u092e \u0938\u093f\u0930\u094d\u092b\u093c \u0909\u0928\u094d\u0939\u0940\u0902 \u091f\u0942\u0932\u094d\u0938 \u0914\u0930 \u0917\u0947\u092e\u094d\u0938 \u0915\u0940 \u0938\u093f\u092b\u093c\u093e\u0930\u093f\u0936 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902 \u091c\u094b \u0939\u092e \u0916\u0941\u0926 \u0907\u0938\u094d\u0924\u0947\u092e\u093e\u0932 \u0915\u0930\u0947\u0902\u0964",
  "about.value2": "\u0908\u092e\u093e\u0928\u0926\u093e\u0930 \u0938\u092e\u0940\u0915\u094d\u0937\u093e\u090f\u0901 \u2014 \u0915\u094b\u0908 \u092a\u094d\u0930\u093e\u092f\u094b\u091c\u0928 \u0928\u0939\u0940\u0902, \u0915\u094b\u0908 \u091b\u093f\u092a\u0947 \u090f\u092b\u093f\u0932\u093f\u090f\u091f\u094d\u0938 \u0928\u0939\u0940\u0902\u0964 \u0938\u093f\u0930\u094d\u092b\u093c \u0938\u091a\u094d\u091a\u0940 \u0930\u093e\u092f\u0964",
  "about.value3": "\u0938\u092c\u0915\u0947 \u0932\u093f\u090f \u0938\u0941\u0932\u092d \u2014 \u0939\u092e\u0947\u0936\u093e \u092e\u0941\u092b\u093c\u094d\u0924, \u0913\u092a\u0928 \u0938\u094b\u0930\u094d\u0938, \u0917\u094b\u092a\u0928\u0940\u092f\u0924\u093e \u0915\u093e \u0938\u092e\u094d\u092e\u093e\u0928\u0964",
  "about.value4": "\u0939\u092e\u0947\u0936\u093e \u0905\u092a\u0921\u0947\u091f\u0947\u0921 \u2014 \u0939\u092e \u0905\u092a\u0928\u0940 \u0938\u093f\u092b\u093c\u093e\u0930\u093f\u0936\u094b\u0902 \u0915\u094b \u0928\u0935\u0940\u0928\u0924\u092e \u091f\u0947\u0915\u094d\u0928\u0949\u0932\u0949\u091c\u0940 \u0915\u0947 \u0938\u093e\u0925 \u0932\u0917\u093e\u0924\u093e\u0930 \u0905\u092a\u0921\u0947\u091f \u0915\u0930\u0924\u0947 \u0930\u0939\u0924\u0947 \u0939\u0948\u0902\u0964",

  "detail.back": "\u0939\u094b\u092e \u092a\u0930 \u0935\u093e\u092a\u0938 \u091c\u093e\u090f\u0902",

