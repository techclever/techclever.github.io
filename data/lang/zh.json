  "about.title": "\u5173\u4e8e TechClever",
  "about.text1": "TechClever \u662f\u4e00\u4e2a\u514d\u8d39\u3001\u65e0\u5e7f\u544a\u7684\u5e73\u53f0\uff0c\u4e3a\u60a8\u7cbe\u9009\u79d1\u6280\u7cbe\u534e\u2014\u2014\u6e38\u620f\u3001AI \u5de5\u5177\u3001\u5f00\u53d1\u8d44\u6e90\u3001\u6548\u7387\u5e94\u7528\u548c\u786c\u4ef6\u6307\u5357\u3002",
  "about.text2": "\u6211\u4eec\u76f8\u4fe1\uff0c\u4f18\u8d28\u7684\u79d1\u6280\u4fe1\u606f\u5e94\u8be5\u8ba9\u6bcf\u4e2a\u4eba\u90fd\u80fd\u83b7\u53d6\uff0c\u6ca1\u6709\u4ed8\u8d39\u5899\u3001\u6807\u9898\u515a\u6216\u9690\u85cf\u76ee\u7684\u3002\u53ea\u6709\u8bda\u5b9e\u3001\u7cbe\u5fc3\u7b5b\u9009\u7684\u63a8\u8350\u3002",
  "about.text3": "\u6ca1\u6709\u8d5e\u52a9\u5185\u5bb9\u3002\u6ca1\u6709\u8054\u76df\u8425\u9500\u5957\u8def\u3002\u53ea\u6709\u4f18\u8d28\u63a8\u8350\uff0c\u6e05\u6670\u660e\u4e86\u3002",
  "about.values_title": "\u6211\u4eec\u7684\u4ef7\u503c\u89c2",
  "about.value1": "\u8d28\u91cf\u91cd\u4e8e\u6570\u91cf\u2014\u2014\u6211\u4eec\u53ea\u63a8\u8350\u81ea\u5df1\u4e5f\u4f1a\u4f7f\u7528\u7684\u5de5\u5177\u548c\u6e38\u620f\u3002",
  "about.value2": "\u8bda\u5b9e\u8bc4\u6d4b\u2014\u2014\u6ca1\u6709\u8d5e\u52a9\uff0c\u6ca1\u6709\u9690\u85cf\u8054\u76df\u3002\u53ea\u6709\u771f\u5b9e\u770b\u6cd5\u3002",
  "about.value3": "\u4eba\u4eba\u53ef\u7528\u2014\u2014\u6c38\u4e45\u514d\u8d39\uff0c\u5f00\u6e90\uff0c\u6ce8\u91cd\u9690\u79c1\u3002",
  "about.value4": "\u59cb\u7ec8\u66f4\u65b0\u2014\u2014\u6211\u4eec\u4fdd\u6301\u63a8\u8350\u5185\u5bb9\u4e0e\u6700\u65b0\u79d1\u6280\u540c\u6b65\u3002",

