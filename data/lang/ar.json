  "about.title": "\u0639\u0646 TechClever",
  "about.text1": "TechClever \u0645\u0646\u0635\u0629 \u0645\u062c\u0627\u0646\u064a\u0629 \u0628\u062f\u0648\u0646 \u0625\u0639\u0644\u0627\u0646\u0627\u062a\u060c \u062a\u0642\u062f\u0645 \u0644\u0643 \u0623\u0641\u0636\u0644 \u0645\u0627 \u0641\u064a \u0639\u0627\u0644\u0645 \u0627\u0644\u062a\u0642\u0646\u064a\u0629 \u2014 \u0627\u0644\u0623\u0644\u0639\u0627\u0628\u060c \u0623\u062f\u0648\u0627\u062a \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a\u060c \u0645\u0648\u0627\u0631\u062f \u0627\u0644\u0645\u0637\u0648\u0631\u064a\u0646\u060c \u062a\u0637\u0628\u064a\u0642\u0627\u062a \u0627\u0644\u0625\u0646\u062a\u0627\u062c\u064a\u0629\u060c \u0648\u0623\u062f\u0644\u0629 \u0627\u0644\u0623\u062c\u0647\u0632\u0629.",
  "about.text2": "\u0646\u0624\u0645\u0646 \u0628\u0623\u0646 \u0627\u0644\u0645\u0639\u0644\u0648\u0645\u0627\u062a \u0627\u0644\u062a\u0642\u0646\u064a\u0629 \u0627\u0644\u062c\u064a\u062f\u0629 \u064a\u062c\u0628 \u0623\u0646 \u062a\u0643\u0648\u0646 \u0645\u062a\u0627\u062d\u0629 \u0644\u0644\u062c\u0645\u064a\u0639\u060c \u0628\u062f\u0648\u0646 \u062c\u062f\u0631\u0627\u0646 \u062f\u0641\u0639\u060c \u0623\u0648 \u0639\u0646\u0627\u0648\u064a\u0646 \u0645\u0636\u0644\u0644\u0629\u060c \u0623\u0648 \u0623\u0647\u062f\u0627\u0641 \u062e\u0641\u064a\u0629. \u0641\u0642\u0637 \u062a\u0648\u0635\u064a\u0627\u062a \u0635\u0627\u062f\u0642\u0629 \u0648\u0645\u062e\u062a\u0627\u0631\u0629 \u0628\u0639\u0646\u0627\u064a\u0629.",
  "about.text3": "\u0644\u0627 \u0645\u062d\u062a\u0648\u0649 \u0645\u0645\u0648\u0644. \u0644\u0627 \u062d\u064a\u0644 \u0625\u0639\u0644\u0627\u0646\u064a\u0629. \u0641\u0642\u0637 \u0627\u062e\u062a\u064a\u0627\u0631\u0627\u062a \u0639\u0627\u0644\u064a\u0629 \u0627\u0644\u062c\u0648\u062f\u0629\u060c \u0645\u0634\u0631\u0648\u062d\u0629 \u0628\u0648\u0636\u0648\u062d.",
  "about.values_title": "\u0642\u064a\u0645\u0646\u0627",
  "about.value1": "\u0627\u0644\u062c\u0648\u062f\u0629 \u0641\u0648\u0642 \u0627\u0644\u0643\u0645 \u2014 \u0646\u0648\u0635\u064a \u0641\u0642\u0637 \u0628\u0627\u0644\u0623\u062f\u0648\u0627\u062a \u0648\u0627\u0644\u0623\u0644\u0639\u0627\u0628 \u0627\u0644\u062a\u064a \u0646\u0633\u062a\u062e\u062f\u0645\u0647\u0627 \u0628\u0623\u0646\u0641\u0633\u0646\u0627.",
  "about.value2": "\u0645\u0631\u0627\u062c\u0639\u0627\u062a \u0635\u0627\u062f\u0642\u0629 \u2014 \u0628\u062f\u0648\u0646 \u0631\u0639\u0627\u064a\u0627\u062a \u0623\u0648 \u0639\u0645\u0648\u0644\u0627\u062a \u062e\u0641\u064a\u0629. \u0641\u0642\u0637 \u0622\u0631\u0627\u0621 \u062d\u0642\u064a\u0642\u064a\u0629.",
  "about.value3": "\u0645\u062a\u0627\u062d \u0644\u0644\u062c\u0645\u064a\u0639 \u2014 \u0645\u062c\u0627\u0646\u064a \u0625\u0644\u0649 \u0627\u0644\u0623\u0628\u062f\u060c \u0645\u0641\u062a\u0648\u062d \u0627\u0644\u0645\u0635\u062f\u0631\u060c \u064a\u062d\u062a\u0631\u0645 \u0627\u0644\u062e\u0635\u0648\u0635\u064a\u0629.",
  "about.value4": "\u062f\u0627\u0626\u0645\u064b\u0627 \u0645\u062d\u062f\u0651\u062b \u2014 \u0646\u062d\u0631\u0635 \u0639\u0644\u0649 \u062a\u062d\u062f\u064a\u062b \u062a\u0648\u0635\u064a\u0627\u062a\u0646\u0627 \u0628\u0627\u0633\u062a\u0645\u0631\u0627\u0631 \u0644\u0645\u0648\u0627\u0643\u0628\u0629 \u0623\u062d\u062f\u062b \u0627\u0644\u062a\u0642\u0646\u064a\u0627\u062a.",

