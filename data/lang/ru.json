  "about.title": "\u041e TechClever",
  "about.text1": "TechClever \u2014 \u044d\u0442\u043e \u0431\u0435\u0441\u043f\u043b\u0430\u0442\u043d\u0430\u044f \u043f\u043b\u0430\u0442\u0444\u043e\u0440\u043c\u0430 \u0431\u0435\u0437 \u0440\u0435\u043a\u043b\u0430\u043c\u044b, \u043a\u043e\u0442\u043e\u0440\u0430\u044f \u0441\u043e\u0431\u0438\u0440\u0430\u0435\u0442 \u043b\u0443\u0447\u0448\u0435\u0435 \u0438\u0437 \u043c\u0438\u0440\u0430 \u0442\u0435\u0445\u043d\u043e\u043b\u043e\u0433\u0438\u0439 \u2014 \u0438\u0433\u0440\u044b, \u0438\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442\u044b \u0418\u0418, \u0440\u0435\u0441\u0443\u0440\u0441\u044b \u0434\u043b\u044f \u0440\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u0447\u0438\u043a\u043e\u0432, \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u044f \u0434\u043b\u044f \u043f\u0440\u043e\u0434\u0443\u043a\u0442\u0438\u0432\u043d\u043e\u0441\u0442\u0438 \u0438 \u0433\u0438\u0434\u044b \u043f\u043e \u043e\u0431\u043e\u0440\u0443\u0434\u043e\u0432\u0430\u043d\u0438\u044e.",
  "about.text2": "\u041c\u044b \u0432\u0435\u0440\u0438\u043c, \u0447\u0442\u043e \u043a\u0430\u0447\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u0430\u044f \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u044f \u043e \u0442\u0435\u0445\u043d\u043e\u043b\u043e\u0433\u0438\u044f\u0445 \u0434\u043e\u043b\u0436\u043d\u0430 \u0431\u044b\u0442\u044c \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u0430 \u043a\u0430\u0436\u0434\u043e\u043c\u0443, \u0431\u0435\u0437 \u043f\u043b\u0430\u0442\u043d\u044b\u0445 \u043f\u043e\u0434\u043f\u0438\u0441\u043e\u043a, \u043a\u043b\u0438\u043a\u0431\u0435\u0439\u0442\u0430 \u0438\u043b\u0438 \u0441\u043a\u0440\u044b\u0442\u044b\u0445 \u043c\u043e\u0442\u0438\u0432\u043e\u0432. \u0422\u043e\u043b\u044c\u043a\u043e \u0447\u0435\u0441\u0442\u043d\u044b\u0435, \u0442\u0449\u0430\u0442\u0435\u043b\u044c\u043d\u043e \u043e\u0442\u043e\u0431\u0440\u0430\u043d\u043d\u044b\u0435 \u0440\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u0430\u0446\u0438\u0438.",
  "about.text3": "\u041d\u0438\u043a\u0430\u043a\u043e\u0433\u043e \u0441\u043f\u043e\u043d\u0441\u0438\u0440\u0443\u0435\u043c\u043e\u0433\u043e \u043a\u043e\u043d\u0442\u0435\u043d\u0442\u0430. \u041d\u0438\u043a\u0430\u043a\u0438\u0445 \u043f\u0430\u0440\u0442\u043d\u0451\u0440\u0441\u043a\u0438\u0445 \u0443\u043b\u043e\u0432\u043e\u043a. \u0422\u043e\u043b\u044c\u043a\u043e \u043a\u0430\u0447\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0435 \u0440\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u0430\u0446\u0438\u0438 \u0441 \u043f\u043e\u043d\u044f\u0442\u043d\u044b\u043c\u0438 \u043e\u0431\u044a\u044f\u0441\u043d\u0435\u043d\u0438\u044f\u043c\u0438.",
  "about.values_title": "\u041d\u0430\u0448\u0438 \u0426\u0435\u043d\u043d\u043e\u0441\u0442\u0438",
  "about.value1": "\u041a\u0430\u0447\u0435\u0441\u0442\u0432\u043e \u0412\u0430\u0436\u043d\u0435\u0435 \u041a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u0430 \u2014 \u041c\u044b \u0440\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u0443\u0435\u043c \u0442\u043e\u043b\u044c\u043a\u043e \u0442\u0435 \u0438\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442\u044b \u0438 \u0438\u0433\u0440\u044b, \u043a\u043e\u0442\u043e\u0440\u044b\u043c\u0438 \u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043b\u0438\u0441\u044c \u0431\u044b \u0441\u0430\u043c\u0438.",
  "about.value2": "\u0427\u0435\u0441\u0442\u043d\u044b\u0435 \u041e\u0431\u0437\u043e\u0440\u044b \u2014 \u041d\u0438\u043a\u0430\u043a\u0438\u0445 \u0441\u043f\u043e\u043d\u0441\u043e\u0440\u043e\u0432, \u043d\u0438\u043a\u0430\u043a\u0438\u0445 \u0441\u043a\u0440\u044b\u0442\u044b\u0445 \u043f\u0430\u0440\u0442\u043d\u0451\u0440\u043e\u043a. \u0422\u043e\u043b\u044c\u043a\u043e \u043d\u0430\u0441\u0442\u043e\u044f\u0449\u0438\u0435 \u043c\u043d\u0435\u043d\u0438\u044f.",
  "about.value3": "\u0414\u043e\u0441\u0442\u0443\u043f\u043d\u043e \u041a\u0430\u0436\u0434\u043e\u043c\u0443 \u2014 \u0411\u0435\u0441\u043f\u043b\u0430\u0442\u043d\u043e \u043d\u0430\u0432\u0441\u0435\u0433\u0434\u0430, \u043e\u0442\u043a\u0440\u044b\u0442\u044b\u0439 \u0438\u0441\u0445\u043e\u0434\u043d\u044b\u0439 \u043a\u043e\u0434, \u0443\u0432\u0430\u0436\u0435\u043d\u0438\u0435 \u043a \u043f\u0440\u0438\u0432\u0430\u0442\u043d\u043e\u0441\u0442\u0438.",
  "about.value4": "\u0412\u0441\u0435\u0433\u0434\u0430 \u0410\u043a\u0442\u0443\u0430\u043b\u044c\u043d\u043e \u2014 \u041c\u044b \u043f\u043e\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0435\u043c \u043d\u0430\u0448\u0438 \u0440\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u0430\u0446\u0438\u0438 \u0432 \u0430\u043a\u0442\u0443\u0430\u043b\u044c\u043d\u043e\u043c \u0441\u043e\u0441\u0442\u043e\u044f\u043d\u0438\u0438.",

